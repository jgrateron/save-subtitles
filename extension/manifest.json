{
  "manifest_version": 3,
  "name": "Save Meet Subtitles",
  "version": "1.0.0",
  "description": "Captura y descarga automáticamente los subtítulos de Google Meet.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
